# Copy this file to .env and fill in real values — never commit .env itself

ELEVENLABS_API_KEY=sk_...

# Pre-Production (test) — limited data, all features enabled
QURAN_FOUNDATION_OAUTH_URL=https://prelive-oauth2.quran.foundation
QURAN_FOUNDATION_API_URL=https://apis-prelive.quran.foundation
QURAN_FOUNDATION_CLIENT_ID=your-client-id-here
QURAN_FOUNDATION_CLIENT_SECRET=your-client-secret-here

# Production (live) — full Qur'an content; switch by uncommenting below and commenting prelive above
# QURAN_FOUNDATION_OAUTH_URL=https://oauth2.quran.foundation
# QURAN_FOUNDATION_API_URL=https://apis.quran.foundation
# QURAN_FOUNDATION_CLIENT_ID=your-prod-client-id-here
# QURAN_FOUNDATION_CLIENT_SECRET=your-prod-client-secret-here
